{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": false,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "*.ts",
    "credentials/**/*.ts",
    "nodes/**/*.ts"
  ],
  "exclude": [
    "dist",
    "tests"
  ]
}
